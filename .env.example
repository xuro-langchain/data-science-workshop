# ── LLM Provider (choose one) ─────────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY="<openai-api-key>"
OPENAI_BASE_URL="<openai-base-url>"   # Optional, defaults to https://api.openai.com/v1

# Anthropic
# ANTHROPIC_API_KEY="<anthropic-api-key>"

# Azure OpenAI
# AZURE_OPENAI_API_KEY="<azure-openai-api-key>"
# AZURE_OPENAI_ENDPOINT="<azure-openai-endpoint>"
# AZURE_OPENAI_API_VERSION=""

# AWS Bedrock
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION_NAME=""
# AWS_MODEL_ARN=""

# Google Vertex AI
# GOOGLE_APPLICATION_CREDENTIALS="./vertexCred.json"

# ── LangSmith (required for eval-driven-dev section) ──────────────────────────

LANGSMITH_API_KEY="<langsmith-api-key>"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"   # or your self-hosted endpoint
LANGSMITH_TRACING="true"
LANGSMITH_PROJECT="email-agent-workshop"
